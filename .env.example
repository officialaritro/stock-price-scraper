# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=raw_ticks
KAFKA_GROUP_ID=stockspy-consumer-group

# MongoDB Configuration
MONGODB_URI=mongodb://stockspy:stockspy@mongodb:27017
MONGODB_DB=stockspy
MONGODB_USER=stockspy
MONGODB_PASSWORD=stockspy

# PostgreSQL Configuration
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=stockspy
POSTGRES_USER=stockspy
POSTGRES_PASSWORD=stockspy

# NSE Configuration
NSE_DOWNLOAD_DIR=/tmp/nse_cache

# Crawler Configuration
CRAWL_INTERVAL_MINUTES=15

# Telegram Configuration (REQUIRED for alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here